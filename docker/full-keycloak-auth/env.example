# Note: this env example file is provided for documentation purposes only; in a Coolify deployment, these environment variables would all be configured via the UI.

# The name of your instance which will appear in the top left of the website
INSTANCE_NAME=

# URL of your own domain (without a scheme or a path, just the domain)
DOMAIN=

# A secret key for the geovisio oauth client in keycloak
OAUTH_CLIENT_SECRET=

# Name of the admin account
KEYCLOAK_ADMIN=admin

# Password of the admin account
KEYCLOAK_ADMIN_PASSWORD=

# [Flask's secret key](https://flask.palletsprojects.com/en/3.0.x/config/#SECRET_KEY). 
# A secret key used among other things for securely signing the session cookie. 
# For production should be provided with a long random string as stated in flask's documentation.
FLASK_SECRET_KEY=

# Password of the postgres db account
PG_PASSWORD=

# Password for the keycloak_user postgres account (used by Keycloak to connect to its DB schema)
KC_DB_PASSWORD=

# S3 storage URLs for pictures (credentials are embedded in the URL)
# Format: s3://ACCESS_KEY:SECRET_KEY@bucket-name/subdir?endpoint_url=<url-encoded-endpoint>&region=<region>
# Note: the endpoint_url value must be percent-encoded (e.g. https:// → https%3A%2F%2F) so the URL
# parser can correctly distinguish it from the rest of the query string.
# Example for OVH Cloud (replace gra with your region, and fill in real credentials and bucket names):
# FS_TMP_URL=s3://ACCESS_KEY:SECRET_KEY@panoramax-private/tmp?endpoint_url=https%3A%2F%2Fs3.gra.io.cloud.ovh.net&region=gra
# FS_PERMANENT_URL=s3://ACCESS_KEY:SECRET_KEY@panoramax-public/main-pictures?endpoint_url=https%3A%2F%2Fs3.gra.io.cloud.ovh.net&region=gra
# FS_DERIVATES_URL=s3://ACCESS_KEY:SECRET_KEY@panoramax-public/derivates?endpoint_url=https%3A%2F%2Fs3.gra.io.cloud.ovh.net&region=gra
FS_TMP_URL=
FS_PERMANENT_URL=
FS_DERIVATES_URL=

# Public-facing base URLs for served pictures (no credentials — used by clients to fetch images directly from S3)
# Example for OVH Cloud: https://panoramax-public.s3.gra.io.cloud.ovh.net/main-pictures
S3_PERMANENT_PUBLIC_URL=
S3_DERIVATES_PUBLIC_URL=

# Number of picture workers: add or remove `background-worker-N` services in docker-compose.yml to adjust the count.

# Tag of the panoramax/api image to deploy. Pin to a specific version (e.g. 1.2.3) to control when you upgrade,
# or leave as `latest` to always pull the newest release.
GEOVISIO_IMAGE_TAG=latest

# Number of proxy before GeoVisio.
# Set it to 2 if you run a reverse proxy before the docker compose (like to handle TLS).
# This parameter is used so that geovisio can trust the `X-Forwarded-` headers for URL generation (more details in the [Flask documentation](https://flask.palletsprojects.com/en/2.2.x/deploying/proxy_fix/)).
# INFRA_NB_PROXIES=2

# Whether the instance is open to self-registration (shown in the website UI and federation metadata)
# Set to False if account creation is admin-only
API_REGISTRATION_IS_OPEN=False

# Change this if you have your own blur API instance
BLUR_API=https://blur.panoramax.openstreetmap.fr

# SMTP settings for Keycloak email verification
# Keycloak sends verification emails when users register or when admins trigger it
SMTP_HOST=
SMTP_PORT=587
SMTP_FROM=
SMTP_FROM_DISPLAY_NAME=Panoramax
SMTP_USER=
SMTP_PASSWORD=
# Use SMTP_SSL=true and SMTP_PORT=465 for implicit TLS (older style)
# Use SMTP_STARTTLS=true and SMTP_PORT=587 for STARTTLS (recommended)
SMTP_SSL=false
SMTP_STARTTLS=true

# ---------- Backups (see BACKUP.md for the full strategy) ----------
# S3-compatible bucket the `backup` service ships encrypted Postgres/Keycloak/secrets
# dumps (via restic) and copies permanent pictures to (via rclone). Separate from
# the production S3 buckets above.
BACKUP_S3_ACCESS_KEY=
BACKUP_S3_SECRET_KEY=
BACKUP_S3_ENDPOINT=
BACKUP_S3_REGION=
BACKUP_S3_BUCKET=panoramax-backup

# Passphrase protecting the restic repository (Postgres dumps, Keycloak export,
# secrets). Store it somewhere independent of the server — it cannot be recovered.
RESTIC_PASSWORD=

# Postgres host/user for the backup service (defaults match the `db` service).
# PGHOST=db
# PGUSER=gvs

# Backup schedule (cron syntax, defaults shown). Keep images before DB if changed —
# see BACKUP.md §10 for why the ordering matters.
# BACKUP_CRON_IMAGES=0 2 * * *
# BACKUP_CRON_DB=30 2 * * *
# BACKUP_CRON_CONFIG=45 2 * * *
# BACKUP_CRON_CHECK=0 4 * * 0

# restic snapshot retention (defaults shown).
# RESTIC_KEEP_DAILY=7
# RESTIC_KEEP_WEEKLY=5
# RESTIC_KEEP_MONTHLY=12
